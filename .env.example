EVOLUTION_INSTANCE=ATRIO-OFFICE

# Nuvem Fiscal (NFS-e)
NUVEM_FISCAL_TOKEN=
NUVEM_FISCAL_ENV=sandbox

# Server
PORT=3010
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# WebSocket
WS_PORT=3011
