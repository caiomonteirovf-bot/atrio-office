{
  "name": "atrio-office-server",
  "version": "1.0.0",
  "description": "\u00c1trio Office \u2014 Backend do escrit\u00f3rio cont\u00e1bil virtual",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "db:create": "psql -U postgres -c 'CREATE DATABASE atrio_office;'",
    "db:schema": "psql -U postgres -d atrio_office -f src/db/schema.sql",
    "db:seed": "psql -U postgres -d atrio_office -f src/db/seed.sql",
    "db:setup": "npm run db:create && npm run db:schema && npm run db:seed",
    "smoke": "node scripts/smoke.mjs",
    "test": "vitest run tests/",
    "test:watch": "vitest tests/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "axios": "^1.15.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "node-telegram-bot-api": "^0.67.0",
    "openai": "^6.33.0",
    "pg": "^8.13.1",
    "qrcode": "^1.5.4",
    "uuid": "^11.1.0",
    "whatsapp-web.js": "^1.34.6",
    "ws": "^8.18.0",
    "pdf-parse": "^1.1.1",
    "multer": "^1.4.5-lts.1",
    "mammoth": "^1.8.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "vitest": "^2.1.9"
  }
}