# PostgreSQL
DATABASE_URL=postgresql://postgres:senha@localhost:5432/atrio_office

# Minimax API
MINIMAX_API_KEY=sua-minimax-api-key
MINIMAX_MODEL=MiniMax-M2.5

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://172.17.0.1:8080
